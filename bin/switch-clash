#!/usr/bin/env bash
set -euo pipefail
CONFIG_DIR="/root/.config/clash"
PROFILE_DIR="$CONFIG_DIR/profiles"
MAP_FILE="$CONFIG_DIR/profile-map.txt"
CLASH_BIN="/root/clash/clash"
CLASH_ARGS="-d $CONFIG_DIR"
CLASH_LOG="/tmp/clash.log"

if [[ $# -lt 1 ]]; then
  echo "用法:"
  echo "  switch-clash 名字"
  echo "  switch-clash list"
  exit 1
fi

cmd="$1"

if [[ "$cmd" == "list" ]]; then
  if [[ -f "$MAP_FILE" ]]; then column -t -s '|' "$MAP_FILE" 2>/dev/null || cat "$MAP_FILE"; else echo "暂无配置"; fi
  exit 0
fi

target="$PROFILE_DIR/${cmd}.yaml"
[[ ! -f "$target" ]] && echo "配置不存在: $target" && exit 1

cp "$target" "$CONFIG_DIR/config.yaml"
echo "已复制配置: $cmd"

# 尝试 systemd 重启
SERVICE_NAME=""
if systemctl list-unit-files 2>/dev/null | grep -q '^clash\.service'; then SERVICE_NAME="clash";
elif systemctl list-unit-files 2>/dev/null | grep -q '^mihomo\.service'; then SERVICE_NAME="mihomo"; fi

if [[ -n "$SERVICE_NAME" ]]; then
  systemctl restart "$SERVICE_NAME"
  sleep 1
  if systemctl is-active --quiet "$SERVICE_NAME"; then
    echo "已切换到: $cmd"
    echo "服务状态: $SERVICE_NAME running"
  else
    echo "切换后服务启动失败，请检查:"
    echo "  systemctl status $SERVICE_NAME"
    exit 1
  fi
else
  # nohup 模式：杀旧进程，启动新进程
  OLD_PID=$(pgrep -f "$CLASH_BIN" 2>/dev/null || true)
  if [[ -n "$OLD_PID" ]]; then
    kill $OLD_PID 2>/dev/null || true
    sleep 1
    # 如果还没退出，强制杀
    kill -0 $OLD_PID 2>/dev/null && kill -9 $OLD_PID 2>/dev/null || true
    sleep 1
  fi
  nohup $CLASH_BIN $CLASH_ARGS >> "$CLASH_LOG" 2>&1 &
  NEW_PID=$!
  sleep 2
  if kill -0 $NEW_PID 2>/dev/null; then
    echo "已切换到: $cmd (PID $NEW_PID)"
    echo "日志: $CLASH_LOG"
  else
    echo "Clash 启动失败，查看日志: $CLASH_LOG"
    tail -20 "$CLASH_LOG"
    exit 1
  fi
fi
